NODE_ENV=development
PORT=3001

# Local development (recommended): docker compose up -d postgres
DATABASE_URL=postgresql://aarental:aarental@127.0.0.1:5433/aarental

# Or Neon/cloud (remove channel_binding from URL if present)
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars!!
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars!!
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
ML_SERVICE_URL=http://localhost:8000
APP_URL=http://localhost:3001
CHAPA_RETURN_URL=http://localhost:45000/payments/complete
