NODE_ENV=development
PORT=3000

# Direct postgresql:// URL required for Nest runtime and seed (not prisma+postgres://)
# Docker Compose: host port for Postgres (5432 is often taken; default 5433)
POSTGRES_PORT=5433
DATABASE_URL=postgresql://aarental:aarental@localhost:5433/aarental

# Comma-separated allowed origins (e.g. Next.js dev server)
CORS_ORIGIN=http://localhost:45000,http://localhost:3000

# Each secret must be at least 32 characters
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars!!
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars!

JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Docker only: set to 1 to run prisma db push on container start
PRISMA_DB_PUSH=0
