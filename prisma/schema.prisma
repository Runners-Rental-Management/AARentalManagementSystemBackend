generator client {
  provider = "prisma-client-js"
  output = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  tenant
  landlord
  admin
}

enum PropertyType {
  apartment
  house
  condominium
  villa
}

enum PropertyStatus {
  pending_verification
  available
  rejected
  rented
}

enum HomeCondition {
  new_build
  excellent
  good
  fair
  needs_renovation
}

enum AgreementStatus {
  draft
  pending_tenant_signature
  pending_verification
  pending_dara_verification
  pending_payment
  active
  extension_requested
  termination_requested
  extended
  terminated
  expired
  rejected
}

enum RentAdjustmentStatus {
  pending
  approved
  rejected
  under_review
}

enum StrategyStatus {
  draft
  published
  archived
}

enum NotificationType {
  info
  warning
  success
  error
}

enum NotificationCategory {
  agreement
  rent_adjustment
  verification
  system
  taxation
}

enum PaymentStatus {
  paid
  pending
  overdue
  partial
}

enum PaymentMethod {
  cbe_birr
  telebirr
  bank_transfer
  mobile_money
  cash
  check
  chapa
}

enum RelatedEntityType {
  agreement
  property
  rent_adjustment
}

enum PenaltyType {
  warning
  fine
  suspension
  legal_action
}

enum PenaltyStatus {
  issued
  acknowledged
  appealed
  enforced
  cancelled
}

enum SystemParameterCategory {
  rental
  compliance
  system
  notification
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  firstName         String
  lastName          String
  phone             String
  role              UserRole
  adminSubCities    String[]  @default([])
  adminAllLocations Boolean   @default(false)
  avatar            String?
  isVerified        Boolean   @default(false)
  address           String?
  idNumber          String?
  fatherName        String?
  grandfatherName   String?
  faydaNumber       String?   @unique
  faydaVerified     Boolean   @default(false)
  faydaVerifiedAt   DateTime?
  passwordHash      String
  lastLoginAt       DateTime?
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  ownedProperties   Property[]         @relation("PropertyLandlord")
  agreementsAsLandlord TenancyAgreement[] @relation("AgreementLandlord")
  agreementsAsTenant   TenancyAgreement[] @relation("AgreementTenant")
  rentAdjustments      RentAdjustment[]   @relation("AdjustmentLandlord")
  receivedNotifications Notification[]
  rentPaymentsAsPayer    RentPayment[]    @relation("PaymentPayer")
  rentPaymentsAsRecipient RentPayment[]   @relation("PaymentRecipient")
  uploadedDocuments      SupportingDocument[] @relation("DocumentUploader")
  auditLogs              AuditLog[]
  issuedPenalties        PenaltyNotice[] @relation("PenaltyIssuer")
  penaltiesReceived      PenaltyNotice[] @relation("PenaltyIssuedTo")
  updatedSystemParameters SystemParameter[]
  authSessions           AuthSession[]
  leaseContracts         LeaseContract[]        @relation("LeaseLandlord")
  leaseContractsAsTenant LeaseContract[]        @relation("LeaseTenant")
  landlordTaxRecords     LandlordTaxRecord[]
  taxCalculationLogs     TaxCalculationLog[]
  terminationRequestsAsLandlord TerminationRequest[] @relation("TerminationLandlord")
  rentIncreaseRequestsAsLandlord RentIncreaseRequest[] @relation("RentIncreaseLandlord")
  complianceViolations   ComplianceViolation[]  @relation("ViolationLandlord")
  complianceViolationsReported ComplianceViolation[] @relation("ViolationReporter")

  @@index([role, createdAt])
  @@index([isVerified, role])
  @@index([deletedAt])
}

model Property {
  id            String         @id @default(cuid())
  title         String
  address       String
  subCity       String
  woreda        String
  propertyType  PropertyType
  bedrooms      Int
  bathrooms     Int
  area          Decimal        @db.Decimal(10, 2)
  amenities     String[]
  monthlyRent   Decimal        @db.Decimal(12, 2)
  status        PropertyStatus @default(pending_verification)
  landlordId    String
  description   String         @db.Text
  images        String[]
  homeCondition       HomeCondition?
  isPostedToExplore   Boolean        @default(false)
  postedToExploreAt   DateTime?
  verifiedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  landlord      User           @relation("PropertyLandlord", fields: [landlordId], references: [id], onDelete: Restrict)
  agreements    TenancyAgreement[]
  documents     SupportingDocument[]
  leaseContracts       LeaseContract[]
  vacancyTracker       PropertyVacancyTracker?
  contractDocuments    ContractDocument[]
  terminationRequests  TerminationRequest[]
  rentIncreaseRequests RentIncreaseRequest[]
  complianceViolations ComplianceViolation[]

  @@index([landlordId, status])
  @@index([subCity, status, monthlyRent])
  @@index([propertyType, status])
  @@index([createdAt])
  @@index([deletedAt])
}

model TenancyAgreement {
  id                 String          @id @default(cuid())
  propertyId         String
  landlordId         String
  tenantId           String
  monthlyRent        Decimal         @db.Decimal(12, 2)
  advancePayment     Decimal         @db.Decimal(12, 2)
  startDate          DateTime
  endDate            DateTime
  status             AgreementStatus @default(draft)
  signedAt           DateTime?
  tenantSignedAt     DateTime?
  landlordSignedAt   DateTime?
  verifiedAt         DateTime?
  initialPaymentAt   DateTime?
  proposedEndDate    DateTime?
  proposedMonthlyRent Decimal?       @db.Decimal(12, 2)
  terminatedAt       DateTime?
  terminationReason  String?         @db.Text
  utilities          String[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  property           Property        @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  landlord           User            @relation("AgreementLandlord", fields: [landlordId], references: [id], onDelete: Restrict)
  tenant             User            @relation("AgreementTenant", fields: [tenantId], references: [id], onDelete: Restrict)
  rentAdjustments    RentAdjustment[]
  rentPayments       RentPayment[]
  penaltyNotices     PenaltyNotice[]
  documents          SupportingDocument[]

  @@index([propertyId, status])
  @@index([landlordId, status])
  @@index([tenantId, status])
  @@index([startDate, endDate])
  @@index([createdAt])
}

model RentAdjustment {
  id                   String               @id @default(cuid())
  agreementId          String
  landlordId           String
  currentRent          Decimal              @db.Decimal(12, 2)
  proposedRent         Decimal              @db.Decimal(12, 2)
  increasePercentage   Decimal              @db.Decimal(5, 2)
  maxAllowedPercentage Decimal              @db.Decimal(5, 2)
  reason               String               @db.Text
  status               RentAdjustmentStatus @default(pending)
  reviewedAt           DateTime?
  reviewedBy           String?
  reviewNotes          String?              @db.Text
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  agreement            TenancyAgreement     @relation(fields: [agreementId], references: [id], onDelete: Restrict)
  landlord             User                 @relation("AdjustmentLandlord", fields: [landlordId], references: [id], onDelete: Restrict)
  documents            SupportingDocument[]

  @@index([agreementId, status])
  @@index([landlordId, createdAt])
  @@index([status, createdAt])
}

model PricingStrategy {
  id                       String           @id @default(cuid())
  title                    String
  description              String           @db.Text
  maxAnnualIncreasePercent Decimal          @db.Decimal(5, 2)
  effectiveFrom            DateTime
  effectiveTo              DateTime
  status                   StrategyStatus   @default(draft)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  publishedAt              DateTime?
  subCityRules             SubCityRule[]

  @@index([status, effectiveFrom, effectiveTo])
}

model SubCityRule {
  id               String         @id @default(cuid())
  pricingStrategyId String
  subCity          String
  maxRentPerSqm    Decimal        @db.Decimal(12, 2)
  adjustmentFactor Decimal        @db.Decimal(6, 3)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  pricingStrategy  PricingStrategy @relation(fields: [pricingStrategyId], references: [id], onDelete: Cascade)

  @@unique([pricingStrategyId, subCity])
  @@index([subCity])
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  title     String
  message   String               @db.Text
  type      NotificationType
  category  NotificationCategory
  isRead    Boolean              @default(false)
  link      String?
  createdAt DateTime             @default(now())
  readAt    DateTime?
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([category, createdAt])
}

model RentPayment {
  id            String        @id @default(cuid())
  agreementId   String
  payerId       String
  recipientId   String
  amount        Decimal       @db.Decimal(12, 2)
  dueDate       DateTime
  paidDate      DateTime?
  status        PaymentStatus @default(pending)
  method        PaymentMethod?
  reference     String?
  chapaTxRef     String?       @unique
  chapaRefId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  agreement     TenancyAgreement @relation(fields: [agreementId], references: [id], onDelete: Restrict)
  payer         User          @relation("PaymentPayer", fields: [payerId], references: [id], onDelete: Restrict)
  recipient     User          @relation("PaymentRecipient", fields: [recipientId], references: [id], onDelete: Restrict)

  @@index([agreementId, dueDate])
  @@index([payerId, status])
  @@index([recipientId, status])
  @@index([status, dueDate])
}

model SupportingDocument {
  id               String            @id @default(cuid())
  uploaderId       String
  relatedEntityType RelatedEntityType
  relatedEntityId  String
  fileName         String
  fileType         String
  fileSize         Int
  storageKey       String            @unique
  description      String?           @db.Text
  uploadedAt       DateTime          @default(now())
  uploader         User              @relation("DocumentUploader", fields: [uploaderId], references: [id], onDelete: Restrict)
  agreementId      String?
  propertyId       String?
  rentAdjustmentId String?
  agreement        TenancyAgreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  property         Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  rentAdjustment   RentAdjustment?   @relation(fields: [rentAdjustmentId], references: [id], onDelete: SetNull)

  @@index([uploaderId, uploadedAt])
  @@index([relatedEntityType, relatedEntityId])
  @@index([agreementId])
  @@index([propertyId])
  @@index([rentAdjustmentId])
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String
  action     String
  entity     String
  entityId   String
  details    String    @db.Text
  ipAddress  String
  userAgent  String?
  timestamp  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, timestamp])
  @@index([entity, entityId, timestamp])
  @@index([action, timestamp])
}

model PenaltyNotice {
  id          String        @id @default(cuid())
  issuedToId  String
  issuedById  String
  agreementId String?
  type        PenaltyType
  reason      String        @db.Text
  amount      Decimal?      @db.Decimal(12, 2)
  status      PenaltyStatus @default(issued)
  issuedAt    DateTime      @default(now())
  deadline    DateTime?
  updatedAt   DateTime      @updatedAt
  issuedTo    User          @relation("PenaltyIssuedTo", fields: [issuedToId], references: [id], onDelete: Restrict)
  issuedBy    User          @relation("PenaltyIssuer", fields: [issuedById], references: [id], onDelete: Restrict)
  agreement   TenancyAgreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)

  @@index([issuedToId, status])
  @@index([issuedById, issuedAt])
  @@index([agreementId])
}

model SystemParameter {
  id          String                  @id @default(cuid())
  key         String                  @unique
  label       String
  value       String                  @db.Text
  category    SystemParameterCategory
  description String                  @db.Text
  updatedAt   DateTime                @updatedAt
  updatedById String
  updatedBy   User                    @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([category])
}

model AuthSession {
  id                 String   @id @default(cuid())
  userId             String
  refreshTokenHash   String
  jti                String   @unique
  userAgent          String?
  ipAddress          String?
  isRevoked          Boolean  @default(false)
  expiresAt          DateTime
  revokedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRevoked])
  @@index([expiresAt])
}

// =============================================================================
// Housing Proclamation No. 1320/2024 — registration, taxation, compliance
// =============================================================================

/// Registered housing contract (authority-approved lease for tax & compliance).
enum LeaseRegistrationStatus {
  draft
  pending_authority
  approved
  rejected
  expired
  terminated
}

enum LandlordTaxRecordStatus {
  draft
  calculated
  notified
  acknowledged
  paid
  disputed
}

enum TaxCalculationLogAction {
  calculate
  recalculate
  bulk_calculate
  notify_email
  pdf_generated
}

enum TerminationRequestStatus {
  pending
  notice_period_active
  approved
  rejected
  withdrawn
  completed
}

enum RentIncreaseRequestStatus {
  pending
  tenant_notified
  under_review
  approved
  rejected
  withdrawn
  applied
}

enum ComplianceViolationType {
  unregistered_lease
  excessive_rent_increase
  insufficient_termination_notice
  tax_non_compliance
  vacancy_underreporting
  tenant_rights_breach
  other
}

enum ComplianceViolationStatus {
  open
  under_investigation
  resolved
  escalated
  dismissed
}

enum ContractDocumentType {
  lease_agreement
  registration_certificate
  tax_assessment
  termination_notice
  rent_increase_notice
  identity_verification
  other
}

/// Formal registered lease (links to platform agreement when applicable).
model LeaseContract {
  id              String                  @id @default(cuid())
  propertyId      String
  landlordId      String
  tenantId        String
  agreementId     String?                 @unique
  registrationNo  String?                 @unique
  monthlyRent     Decimal                 @db.Decimal(12, 2)
  startDate       DateTime
  endDate         DateTime
  status          LeaseRegistrationStatus @default(draft)
  /// Authority approval timestamp — required for tax income recognition.
  approvedAt      DateTime?
  approvedById    String?
  utilities       String[]                @default([])
  depositAmount   Decimal?                @db.Decimal(12, 2)
  noticePeriodDays Int                    @default(30)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  property        Property                @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  landlord        User                    @relation("LeaseLandlord", fields: [landlordId], references: [id], onDelete: Restrict)
  tenant          User                    @relation("LeaseTenant", fields: [tenantId], references: [id], onDelete: Restrict)
  documents       ContractDocument[]
  terminationRequests TerminationRequest[]
  rentIncreaseRequests RentIncreaseRequest[]

  @@index([landlordId, status])
  @@index([propertyId, status])
  @@index([tenantId, status])
  @@index([approvedAt])
  @@index([startDate, endDate])
}

/// Annual landlord rental income tax assessment (informational; payment to authority).
model LandlordTaxRecord {
  id                     String                  @id @default(cuid())
  landlordId             String
  taxYear                Int
  grossAnnualIncome      Decimal                 @db.Decimal(14, 2)
  occupiedMonths         Decimal                 @db.Decimal(6, 2)
  vacancyMonths          Decimal                 @db.Decimal(6, 2)
  potentialVacancyIncome Decimal                 @db.Decimal(14, 2)
  totalTaxableIncome     Decimal                 @db.Decimal(14, 2)
  calculatedTaxAmount    Decimal                 @db.Decimal(14, 2)
  taxRateApplied         Decimal                 @db.Decimal(5, 4)
  status                 LandlordTaxRecordStatus @default(calculated)
  notificationSent       Boolean                 @default(false)
  notificationSentAt     DateTime?
  calculationNotes       String?                 @db.Text
  breakdownJson          Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  landlord               User                    @relation(fields: [landlordId], references: [id], onDelete: Restrict)

  @@unique([landlordId, taxYear])
  @@index([landlordId, taxYear])
  @@index([taxYear, status])
  @@index([notificationSent])
}

/// Tracks current vacancy for a property (updated by cron).
model PropertyVacancyTracker {
  id                  String    @id @default(cuid())
  propertyId          String    @unique
  landlordId          String
  vacancyStartDate    DateTime
  lastLeaseEndDate    DateTime?
  daysVacant          Int       @default(0)
  monthlyRent         Decimal   @db.Decimal(12, 2)
  isLongTermVacancy   Boolean   @default(false)
  /// Proclamation: gaps >180 days may be deemed taxable potential income.
  longTermThresholdDays Int     @default(180)
  landlordNotifiedAt  DateTime?
  estimatedVacancyTax Decimal?  @db.Decimal(14, 2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([landlordId, isLongTermVacancy])
  @@index([daysVacant])
  @@index([isLongTermVacancy, daysVacant])
}

/// Audit trail for all tax computations.
model TaxCalculationLog {
  id           String                  @id @default(cuid())
  landlordId   String
  taxYear      Int
  action       TaxCalculationLogAction
  performedById String?
  inputJson    Json?
  resultJson   Json?
  errorMessage String?                 @db.Text
  createdAt    DateTime                @default(now())
  landlord     User                    @relation(fields: [landlordId], references: [id], onDelete: Restrict)

  @@index([landlordId, taxYear])
  @@index([action, createdAt])
  @@index([createdAt])
}

/// Lease termination with statutory notice period tracking.
model TerminationRequest {
  id                String                   @id @default(cuid())
  leaseContractId   String?
  agreementId       String?
  propertyId        String
  landlordId        String
  tenantId          String
  requestedById     String
  reason            String                   @db.Text
  requestedEndDate  DateTime
  noticePeriodDays  Int
  noticeServedAt    DateTime                 @default(now())
  earliestEndDate DateTime
  status            TerminationRequestStatus @default(pending)
  reviewedById      String?
  reviewedAt        DateTime?
  reviewNotes       String?                  @db.Text
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  leaseContract     LeaseContract?           @relation(fields: [leaseContractId], references: [id], onDelete: SetNull)
  property          Property                 @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  landlord          User                     @relation("TerminationLandlord", fields: [landlordId], references: [id], onDelete: Restrict)

  @@index([landlordId, status])
  @@index([tenantId, status])
  @@index([propertyId, status])
  @@index([status, createdAt])
}

/// Rent increase request (separate from RentAdjustment workflow; proclamation limits).
model RentIncreaseRequest {
  id                 String                    @id @default(cuid())
  leaseContractId    String?
  agreementId        String?
  propertyId         String
  landlordId         String
  tenantId           String
  currentRent        Decimal                   @db.Decimal(12, 2)
  proposedRent       Decimal                   @db.Decimal(12, 2)
  increasePercent    Decimal                   @db.Decimal(5, 2)
  maxAllowedPercent  Decimal                   @db.Decimal(5, 2)
  effectiveDate      DateTime
  justification      String                    @db.Text
  status             RentIncreaseRequestStatus @default(pending)
  tenantNotifiedAt   DateTime?
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  leaseContract      LeaseContract?            @relation(fields: [leaseContractId], references: [id], onDelete: SetNull)
  property           Property                  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  landlord           User                      @relation("RentIncreaseLandlord", fields: [landlordId], references: [id], onDelete: Restrict)

  @@index([landlordId, status])
  @@index([propertyId, status])
  @@index([status, createdAt])
}

/// Documents attached to registered leases.
model ContractDocument {
  id              String               @id @default(cuid())
  leaseContractId String?
  propertyId      String?
  documentType    ContractDocumentType
  fileName        String
  fileType        String
  fileSize        Int
  storageKey      String               @unique
  uploadedById    String
  description     String?              @db.Text
  uploadedAt      DateTime             @default(now())
  leaseContract   LeaseContract?       @relation(fields: [leaseContractId], references: [id], onDelete: SetNull)
  property        Property?            @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([leaseContractId])
  @@index([propertyId])
  @@index([documentType])
}

/// Authority-tracked proclamation violations.
model ComplianceViolation {
  id             String                    @id @default(cuid())
  landlordId     String?
  propertyId     String?
  reportedById   String
  violationType  ComplianceViolationType
  description    String                    @db.Text
  status         ComplianceViolationStatus @default(open)
  resolutionNotes String?                  @db.Text
  resolvedAt     DateTime?
  dueDate        DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  landlord       User?                     @relation("ViolationLandlord", fields: [landlordId], references: [id], onDelete: SetNull)
  property       Property?                 @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  reportedBy     User                      @relation("ViolationReporter", fields: [reportedById], references: [id], onDelete: Restrict)

  @@index([landlordId, status])
  @@index([propertyId, status])
  @@index([violationType, status])
  @@index([status, createdAt])
}
